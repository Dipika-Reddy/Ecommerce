generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  isAdmin         Boolean   @default(false)
  isSuperAdmin    Boolean   @default(false)
  isDeliveryAgent Boolean   @default(false)
  isSupport       Boolean   @default(false)
  shippingAddress Json?
  phoneNumber     String?
  panNumber       String?
  gstNumber       String?
  licensePicture  String?
  passportPhoto   String?
  drivingLicense  String?
  bikeNumberPlate String?
  bikeRegistration String?
  sellerStatus    String    @default("NONE")
  deliveryStatus  String    @default("NONE")
  resetOtp        String?
  resetOtpExpiry  DateTime?
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]
  reviews         Review[]
  orders          Order[]     @relation("CustomerOrder")
  deliveryOrders  Order[]     @relation("DeliveryAgentOrder")
  payments        Payment[]
  customerCalls   HelplineCall[] @relation("CustomerCalls")
  agentCalls      HelplineCall[] @relation("AgentCalls")
  supportActions  SupportActionLog[] @relation("AgentActions")
}

model HelplineCall {
  id             String    @id @default(uuid())
  customerId     String?
  customer       User?     @relation("CustomerCalls", fields: [customerId], references: [id], onDelete: SetNull)
  customerName   String
  customerPhone  String
  agentId        String
  agent          User      @relation("AgentCalls", fields: [agentId], references: [id], onDelete: Cascade)
  notes          String?
  createdAt      DateTime  @default(now())
}

model Product {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  images       String[]
  brand        String
  category     String
  subCategory  String?
  description  String
  rating       Float       @default(0)
  numReviews   Int         @default(0)
  price        Float       @default(0)
  countInStock Int         @default(0)
  sizes        String[]
  colors       String[]
  reviews      Review[]
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  name      String
  rating    Int
  comment   String
  image     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation("CustomerOrder", fields: [userId], references: [id], onDelete: Cascade)
  deliveryAgentId String?
  deliveryAgent   User?       @relation("DeliveryAgentOrder", fields: [deliveryAgentId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  shippingAddress Json
  paymentMethod   String
  paymentResult   Json?
  itemsPrice      Float       @default(0.0)
  shippingPrice   Float       @default(0.0)
  taxPrice        Float       @default(0.0)
  totalPrice      Float       @default(0.0)
  isPaid          Boolean     @default(false)
  paidAt          DateTime?
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?
  status          String      @default("Pending")
  returnReason    String?
  returnImage     String?
  returnStatus    String?     // 'Requested', 'Approved', 'Collected', 'Rejected'
  refundDetails   String?     // To store UPI/Card details for COD returns
  isRefunded      Boolean     @default(false)
  couponCode      String?
  couponDiscount  Float       @default(0.0)
  assignedBy      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  payments        Payment[]
  supportActions  SupportActionLog[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  qty       Int
  image     String
  price     Float
  size      String?
  color     String?
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("INR")
  paymentMethod String
  transactionId String?
  gateway       String   @default("RAZORPAY")
  paymentStatus String   // e.g. "PENDING", "SUCCESS", "FAILED", "REFUNDED"
  refunds       Refund[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Refund {
  id           String   @id @default(uuid())
  paymentId    String
  payment      Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  refundAmount Float
  refundReason String
  refundStatus String   // e.g. "PENDING", "SUCCESS", "FAILED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   // 'PERCENTAGE' or 'FIXED'
  discountValue Float
  minPurchase   Float    @default(0.0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SupportActionLog {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agentId     String
  agent       User     @relation("AgentActions", fields: [agentId], references: [id], onDelete: Cascade)
  action      String
  details     String
  createdAt   DateTime @default(now())
}

